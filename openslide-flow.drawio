    <mxCell id="s1" value="1. 安裝 Node.js（LTS 版本）&#xa;下載 nodejs.org，輸入 node -v 確認" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
