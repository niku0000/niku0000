      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="s4" value="4. 設定 Git 身分（一次）&#xa;git config --global user.email &quot;你的email&quot;&#xa;git config --global user.name &quot;你的名字&quot;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
