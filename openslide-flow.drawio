    <mxCell id="e_s1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="setup_header" target="s1" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <mxCell id="s2" value="2. 安裝 pnpm&#xa;用 cmd 輸入：npm install -g pnpm&#xa;⚠️ 用 cmd，不要用 PowerShell" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
