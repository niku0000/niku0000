    </mxCell>

    <mxCell id="s5" value="5. 下載專案到本機&#xa;git clone https://github.com/niku0000/niku0000.git" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
